{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "rebaseWhen": "auto",
  "packageRules": [
    {
      "matchPackageNames": ["@angular/language-service", "@angular/core", "monaco-editor"],
      "stabilityDays": 0
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}